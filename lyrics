<title>Hymn Sing — Christian Retreat</title>
<style>
  :root {
    --bg: #fafaf7;
    --ink: #1a1a1a;
    --muted: #6b6b6b;
    --accent: #5b3a29;
    --rule: #e2ddd2;
    --max: 720px;
  }

  * { box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
    scroll-padding-top: 1rem;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 18px;
    line-height: 1.6;
    padding: 1.25rem 1.1rem 4rem;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
  }

  /* Header */
  header.top {
    text-align: center;
    padding: 1.5rem 0 1rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1.5rem;
  }
  header.top h1 {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: clamp(1.8rem, 6vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 0.25rem;
  }
  header.top p.subtitle {
    margin: 0;
    color: var(--muted);
    font-style: italic;
    font-size: 1rem;
  }

  /* Index */
  nav.index {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 2rem;
  }
  nav.index h2 {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  ol.index-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: hymn;
  }
  ol.index-list li {
    counter-increment: hymn;
    border-bottom: 1px solid var(--rule);
  }
  ol.index-list li:last-child { border-bottom: none; }
  ol.index-list li a {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.85rem 0;
    color: var(--ink);
    text-decoration: none;
    font-size: 1.05rem;
    min-height: 44px; /* mobile tap target */
  }
  ol.index-list li a::before {
    content: counter(hymn);
    flex-shrink: 0;
    width: 1.75rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }
  ol.index-list li a:hover,
  ol.index-list li a:focus {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Songs */
  section.song {
    padding-top: 1.5rem;
    margin-top: 2rem;
    border-top: 1px solid var(--rule);
    scroll-margin-top: 1rem;
  }
  section.song:first-of-type {
    border-top: none;
    margin-top: 0;
  }

  h2.song-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: clamp(1.5rem, 5vw, 1.85rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }

  .stanza {
    margin: 0 0 1.4rem;
  }

  .section-label {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.45rem;
  }

  .lyric-line {
    margin: 0;
    padding: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .stanza.chorus {
    padding-left: 1.25rem;
    border-left: 2px solid var(--rule);
  }
  .stanza.chorus .section-label {
    color: var(--accent);
  }

  .back-to-top {
    margin: 1.75rem 0 0;
    text-align: right;
    font-size: 0.9rem;
  }
  .back-to-top a {
    color: var(--muted);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    display: inline-block;
    min-height: 44px;
    line-height: 1.5;
  }
  .back-to-top a:hover,
  .back-to-top a:focus {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #14130f;
      --ink: #ece8e0;
      --muted: #9c958a;
      --accent: #d4a574;
      --rule: #2c2a25;
    }
    nav.index { background: #1c1b17; }
  }

  /* Larger phones / tablets */
  @media (min-width: 600px) {
    body { font-size: 19px; padding: 2rem 1.5rem 5rem; }
    .lyric-line { font-size: 1.1rem; line-height: 1.6; }
  }

  /* Print: clean, single-column, no nav */
  @media print {
    :root { --bg: #fff; --ink: #000; --muted: #444; --rule: #ccc; }
    body { font-size: 11pt; padding: 0; }
    nav.index, .back-to-top { display: none; }
    section.song { page-break-before: always; border-top: none; }
    section.song:first-of-type { page-break-before: auto; }
  }
</style>
</head>
